rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserIsAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('blocked', false) == false;
    }

    function ownerIsActive(userId) {
      return signedIn()
        && request.auth.uid == userId
        && get(/databases/$(database)/documents/users/$(userId)).data.get('blocked', false) == false;
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || currentUserIsAdmin());
      allow list: if currentUserIsAdmin();
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.get('role', 'user') == 'user'
        && request.resource.data.get('blocked', false) == false;
      allow update: if currentUserIsAdmin() || (ownerIsActive(userId)
        && request.resource.data.get('role', 'user') == resource.data.get('role', 'user')
        && request.resource.data.get('blocked', false) == resource.data.get('blocked', false)
        && request.resource.data.get('blockedAt', null) == resource.data.get('blockedAt', null)
        && request.resource.data.get('blockedBy', null) == resource.data.get('blockedBy', null));
      allow delete: if ownerIsActive(userId);

      match /{document=**} {
        allow read, write: if ownerIsActive(userId);
      }
    }

    match /userVisits/{visitId} {
      allow create: if signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('blocked', false) == false
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.visitedAt == request.time;
      allow read: if currentUserIsAdmin();
      allow update, delete: if false;
    }
  }
}
